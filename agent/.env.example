# --- Agente de aprendizajes (VPS) — mismo patrón que el CRM ---
# Copia a .env. NO subas .env al repo.

# URL pública de tu app (la de Vercel, sin barra final). La usa aprendizajes.mjs
# para llamar a /api/agent.
APP_BASE_URL=https://TU-APP-REAL.vercel.app

# Secreto compartido con la app para /api/agent. Debe ser IDÉNTICO al AGENT_TOKEN
# que pongas en Vercel.  Genera uno:  openssl rand -hex 32
AGENT_TOKEN=

# --- Cerebro para la APP (brain-server.mjs): IA sin coste de API ---
# Secreto compartido con la app para /complete. IDÉNTICO al BRAIN_TOKEN de Vercel.
BRAIN_TOKEN=
BRAIN_PORT=8788
# Modelo: "sonnet" (rápido) u "opus" (máxima calidad). Si lo dejas vacío usa el del SDK.
BRAIN_MODEL=sonnet

# La suscripción de Claude (la MISMA que usa el agente del CRM). Si vas a meter
# aprendizajes dentro del asistente del CRM, ya está en su .env y no hace falta
# repetirlo. Para el brain-server como servicio aparte, sí.
#   Generar/renovar con:  claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=
